{
  "name": "rebirth",
  "version": "0.10.2",
  "private": true,
  "type": "module",
  "bin": {
    "rebirth": "./dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cap": "mv src/app/api src/_api_tmp && CAPACITOR_BUILD=1 next build; mv src/_api_tmp src/app/api",
    "build:cap:e2e": "NEXT_PUBLIC_E2E=1 npm run build:cap",
    "cap:sync": "npx cap sync ios && node scripts/cap-post-sync.mjs && npm run gen:healthkit",
    "gen:healthkit": "node scripts/gen-healthkit-types.mjs",
    "start": "next start",
    "lint": "next lint",
    "test:maestro": "bash scripts/maestro-run.sh run",
    "test:maestro:full": "bash scripts/maestro-run.sh full",
    "test:maestro:watch": "bash scripts/maestro-run.sh watch",
    "test:maestro:studio": "bash scripts/maestro-run.sh studio",
    "test:maestro:failed": "bash scripts/maestro-run.sh failed",
    "test:maestro:tree": "bash scripts/maestro-run.sh tree",
    "test:maestro:doctor": "bash scripts/maestro-run.sh doctor",
    "test:maestro:lint": "node scripts/maestro-selector-lint.mjs",
    "check:no-test-bridge": "bash scripts/check-no-test-bridge.sh",
    "check:no-sw": "bash scripts/check-no-sw-in-capacitor-build.sh",
    "ship:checks": "bash scripts/ship-checks.sh",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:check": "tsx src/db/migrate.ts check",
    "db:rollback": "tsx src/db/migrate.ts rollback",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed-routines": "tsx src/db/seed-routines.ts",
    "db:dedupe-exercises": "tsx src/db/deduplicate-exercises.ts",
    "db:apply-image-counts": "node scripts/db-apply-image-counts.mjs",
    "fetch-everkinetic-images": "node scripts/fetch-everkinetic-images.mjs",
    "gen-exercise-images": "node scripts/gen-exercise-images.mjs",
    "cli:build": "tsc src/cli.ts --outDir dist --module nodenext --moduleResolution nodenext --target es2022 --esModuleInterop --skipLibCheck",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "ios:device": "npm run gen:healthkit && bash scripts/ios-device-build.sh"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/local-notifications": "^8.0.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@neondatabase/serverless": "^0.10.4",
    "@tanstack/react-query": "^5.95.2",
    "@tensorflow-models/face-detection": "^1.0.3",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "@tensorflow/tfjs-converter": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "@vercel/blob": "^0.27.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^12.1.0",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "fflate": "^0.8.2",
    "lucide-react": "^0.577.0",
    "next": "^15.5.12",
    "openai": "^6.35.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-muscle-highlighter": "^1.2.0",
    "recharts": "^3.8.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "15.1.4",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.2",
    "typescript": "5.9.3",
    "vitest": "^4.1.0"
  }
}
