# Database Connection
# Get this from Neon Console: https://console.neon.tech
POSTGRES_URL="postgresql://user:password@ep-example.neon.tech/dbname?sslmode=require"

# Alternative env var name (Vercel uses this)
DATABASE_URL="postgresql://user:password@ep-example.neon.tech/dbname?sslmode=require"

# Rebirth API key — protects all /api/* routes from external access.
# Generate with: openssl rand -hex 32
# If unset, all routes are open (dev mode only — set this in production).
REBIRTH_API_KEY=""

# Public mirror of REBIRTH_API_KEY — baked into the client bundle so Capacitor
# (iOS / Android) can authenticate against the production server. MUST equal
# REBIRTH_API_KEY whenever the server enforces auth, or the iOS app will see
# 401s on every protected route (projection-photos, inspo-photos, etc.).
# In a single-user app the API key is effectively a shared secret between
# client and server — this is the documented Rebirth pattern.
NEXT_PUBLIC_REBIRTH_API_KEY=""

# MCP-specific secret — used by /api/mcp (Bearer header) and /api/mcp/<secret> (URL path for Claude Web).
# Takes precedence over REBIRTH_API_KEY for MCP routes. Generate with: openssl rand -hex 32
REBIRTH_MCP_SECRET=""

# OpenAI API key — required for exercise demo image generation
# (in-app /api/exercises/[uuid]/generate-images + scripts/gen-exercise-images.mjs).
# Uses gpt-image-1; ~$0.19 per exercise (one 1024x1536 portrait composite).
OPENAI_API_KEY=""
